{
  "name": "exercises-player",
  "version": "1.0.0",
  "private": true,
  "description": "ExercisesPlayer - 离线健身动作库",
  "engines": {
    "node": ">=18"
  },
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "none"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "build:rn": "taro build --type rn",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "dev:rn": "npm run build:rn -- --watch",
    "lint": "eslint src --ext .ts,.tsx,.vue --fix"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-vue3": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@babel/runtime": "^7.7.7",
    "@tarojs/cli": "4.2.0",
    "@tarojs/vite-runner": "4.2.0",
    "@types/node": "^20.11.0",
    "@unocss/preset-uno": "^0.58.0",
    "@unocss/transformer-directives": "^0.58.0",
    "@vitejs/plugin-vue": "^4.6.0",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "babel-preset-taro": "4.2.0",
    "eslint": "^8.56.0",
    "eslint-config-taro": "4.2.0",
    "postcss": "^8.4.33",
    "typescript": "^5.3.3",
    "unocss": "^0.58.0",
    "unocss-preset-weapp": "^0.58.0",
    "vite": "^4.5.0"
  }
}
